MICROSOFT_AUTH_MODE=delegated
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
MICROSOFT_TENANT_ID=consumers
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_MAILBOX=
MICROSOFT_TOKEN_CACHE_PATH=data/msal_token_cache.json
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=change-me
# BASE_URL is the ngrok tunnel URL (e.g. https://abcd-1234.ngrok-free.app).
# Update this every time ngrok restarts — it is the only URL you need to change.
# TELEGRAM_WEBHOOK_URL is optional: if omitted it defaults to BASE_URL automatically.
BASE_URL=https://your-ngrok-url.ngrok-free.app
# TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app  # optional, defaults to BASE_URL
DATABASE_URL=sqlite+aiosqlite:///./data/email_automation.db
ATTACHMENT_STORAGE_PATH=data/attachments
POLLING_INTERVAL_SECONDS=60
MATCH_THRESHOLD=65
SUPPLIER_OFFER_TTL_DAYS=30
COMPANY_NAME=Your Company
SALES_SIGNATURE=Equipo Comercial
